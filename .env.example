# Copia este archivo a .env y ajusta los valores para tu entorno local.
# .env está en .gitignore: nunca se versiona.

# ── Backend Flask ────────────────────────────────────────
FLASK_APP=app
FLASK_DEBUG=1

# ── Base de datos (coincide con docker-compose.yml) ──────
DATABASE_URL=postgresql://lsp:lsp_dev@localhost:5432/diccionario_lsp

# ── Módulo de IA ─────────────────────────────────────────
# Umbral de confianza para aceptar una predicción (tesis: 0.8)
UMBRAL_CONFIANZA=0.8
# Ruta del modelo entrenado (formato nativo Keras)
RUTA_MODELO=../ml/modelos/modelo.keras
# Mapa canónico letra <-> índice de clase
RUTA_CLASES=../ml/modelos/clases.json

# ── Medios estáticos ─────────────────────────────────────
# Directorio de GIFs servidos por el backend
MEDIA_GIFS_DIR=../media/gifs

# ── Importador (RF11) ────────────────────────────────────
# API de señas para sincronización de contenido (pendiente de definir)
API_SENAS_URL=
API_SENAS_TOKEN=
